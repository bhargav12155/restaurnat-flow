# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Never commit your real `.env`.

# --- Core app ---
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# Postgres / Drizzle
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

# Auth / Sessions
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me
API_KEY_ENCRYPTION_SECRET=change-me

# --- AI providers ---
OPENAI_API_KEY=
OPENAI_KEY=
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=
OPENAI_API_KEY_4=
OPENAI_API_KEY_PREMIUM=
GEMINI_API_KEY=

# Optional internal/external AI endpoints
COPILOT_API_URL=
AI_SEO_SERVICE_URL=
AI_SEO_SERVICE_API_KEY=

# --- HeyGen ---
HEYGEN_API_KEY=
HEYGEN_WEBHOOK_URL=
HEYGEN_WEBHOOK_SECRET=
PHOTO_AVATAR_SERVICE_URL=

# --- Kling ---
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# --- Twilio ---
TWILIO_AUTH_TOKEN=

# --- Social integrations ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_USER_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

INSTAGRAM_CLIENT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_ACCESS_TOKEN=

# --- Media / assets ---
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
YOUTUBE_SAMPLE_VIDEO_PATH=
SOCIAL_TEST_IMAGE_URL=

# --- Storage ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_S3_BUCKET=

# Object storage helpers
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

# --- MLS / IDX ---
PARAGON_APP_ID=
PARAGON_API_TOKEN=
SIMPLYRETS_USERNAME=
SIMPLYRETS_PASSWORD=

# --- Replit (optional) ---
REPL_ID=
REPLIT_DEV_DOMAIN=
